<Project>
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <WindowsInstallerProject>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\..\PS-SZC.Installer\PS-SZC.Installer.wixproj'))</WindowsInstallerProject>
    <WindowsInstallerName>PS-SZC.msi</WindowsInstallerName>
    <WindowsInstallerOutputDir>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\..\PS-SZC.Installer\bin\x64\$(Configuration)'))</WindowsInstallerOutputDir>
    <WindowsInstallerOutput>$(WindowsInstallerOutputDir)\$(WindowsInstallerName)</WindowsInstallerOutput>
    <AppPublishDir>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\bin\$(Configuration)\net10.0\win-x64\publish\'))</AppPublishDir>
  </PropertyGroup>

  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows')) and '$(SkipCreateWindowsInstaller)' != 'true'">
    <RunPostBuildEvent>OnBuildSuccess</RunPostBuildEvent>
    <PostBuildEvent>dotnet restore "$(MSBuildProjectFullPath)" -r win-x64&#xD;&#xA;dotnet publish "$(MSBuildProjectFullPath)" -c $(Configuration) -r win-x64 --no-self-contained /p:SkipCreateWindowsInstaller=true /p:PublishSingleFile=false /p:PublishDir="$(AppPublishDir)"&#xD;&#xA;dotnet build "$(WindowsInstallerProject)" -c $(Configuration) /p:SkipPublishApp=true /p:Platform=x64&#xD;&#xA;copy /Y "$(WindowsInstallerOutput)" "$(TargetDir)$(WindowsInstallerName)"</PostBuildEvent>
  </PropertyGroup>
</Project>
